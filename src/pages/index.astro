---
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import About from "../components/About.astro";
import Projects from "../components/Projects.astro";
import Achievements from "../components/Achievements.astro";
import Experience from "../components/Experience.astro";
import Education from "../components/Education.astro";
import Footer from "../components/Footer.astro";
import { siteConfig } from "../config";
import "../styles/global.css";
import assistantAvatar from "../../assets/me_assistant_avatar.png";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={siteConfig.description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;1,100;1,200;1,300;1,400;1,500;1,600;1,700&display=swap"
      rel="stylesheet"
    />
    <title>{siteConfig.name} - {siteConfig.title}</title>
  </head>

  <body>
    <Header />
    <section>
      <Hero />
      <About />
      <Projects />
      <Experience />
      <Achievements />
      <Education />
    </section>
    <Footer />
    <div id="assistant-root">
      <!-- Speech bubble -->
      <div id="assistant-bubble" class="assistant-bubble">
        Hi there! Need any help?
      </div>
    
      <!-- Avatar button -->
      <button id="assistant-fab" aria-label="Open Assistant">
        <img src={assistantAvatar.src} alt="Assistant" />
      </button>
    </div>
    
    <!-- Assistant Dialog -->
    <div id="assistant-dialog" class="assistant-hidden">
      <div class="assistant-modal">
        <button id="assistant-close">✕</button>
    
        <iframe
          src="https://huggingface.co/spaces/srk-dot-ai/suhas-rk-professional-assistant/embed"
          allow="clipboard-write"
        ></iframe>
      </div>
    </div>

    <script is:inline>
      document.addEventListener("DOMContentLoaded", () => {
        const fab = document.getElementById("assistant-fab");
        const dialog = document.getElementById("assistant-dialog");
        const closeBtn = document.getElementById("assistant-close");
        const bubble = document.getElementById("assistant-bubble");
    
        if (!fab || !dialog || !closeBtn || !bubble) return;
    
        /* ---------- Bubble on every load ---------- */
        setTimeout(() => bubble.classList.add("show"), 900);
    
        /* ---------- Open dialog ---------- */
        fab.addEventListener("click", () => {
          dialog.classList.remove("assistant-hidden");
          bubble.classList.remove("show");
        });
    
        /* ---------- Close ---------- */
        closeBtn.addEventListener("click", () => {
          dialog.classList.add("assistant-hidden");
        });
    
        dialog.addEventListener("click", (e) => {
          if (e.target === dialog) {
            dialog.classList.add("assistant-hidden");
          }
        });
      });
    </script>
  </body>
</html>
